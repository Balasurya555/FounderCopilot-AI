# FounderCopilot AI – Environment Variables
# Rename this file to .env and fill in your API keys

# Gemini API key – used for the chatbot and SVG logo generation
GEMINI_API_KEY=your_gemini_api_key_here

# Imagen API key – used for high-quality logo image generation
# (Can be the same as GEMINI_API_KEY or a dedicated key)
LOGO_API_KEY=your_logo_api_key_here

# Port the backend server listens on
PORT=5000
