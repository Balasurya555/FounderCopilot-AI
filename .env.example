# Example environment variables for local development.
# Copy this file to .env.local and fill in your real secrets.
# IMPORTANT: Never commit real API keys to source control.

# Primary backend API key for OpenAI-compatible requests (required)
OPENAI_API_KEY=your_openai_key_here

# Public contract address (frontend-safe if needed)
NEXT_PUBLIC_CONTRACT_ADDRESS=your_contract_address_here

# Optional: Legacy or alternative keys used by some tools (do NOT expose these to frontend)
# Gemini API key (backend-only). Do NOT expose this to the frontend.
GEMINI_API_KEY=AIzaSyDOZ79J-77rsdlw9y3bXRf0mp453eGMTY4
# LOGO_API_KEY=your_logo_api_key_here

# APP_URL: The URL where this app is hosted (optional)
APP_URL=YOUR_APP_URL_HERE
# Backend base URL used by the frontend at build time (Vite). Set this in Vercel environment variables to your backend host.
VITE_BACKEND_URL=http://localhost:5000
